# FinLakehouse entity .env template
# Copy to /opt/finlakehouse/.env on the VPS and fill in every value.
# Never commit this file; it carries credentials.
#
# Derived from: SoloLakehouse product-entity-contract.md
# Template version: slh-v2.5.1 + ADR-020 (all-layer Iceberg)

# --- Iceberg / Hive Metastore ---
HIVE_METASTORE_URI=thrift://localhost:9083

# --- Runtime identity (stable logical fields) ---
PRODUCT_ID=finlakehouse
PRODUCT_DISPLAY_NAME=FinLakehouse
PRODUCT_DOMAIN=financial_markets
ENVIRONMENT=prod
RUNTIME_VERSION=slh-v2.5.1
COMPOSE_PROJECT_NAME=finlakehouse
TRINO_USER=finlakehouse

# --- MinIO credentials (change these) ---
MINIO_ROOT_USER=finlakehouse
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password_here
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- PostgreSQL credentials (change these) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
PG_PORT=5432

# --- S3 / MinIO access (keep in sync with MINIO_ROOT_USER/PASSWORD) ---
S3_ACCESS_KEY=finlakehouse
S3_SECRET_KEY=CHANGE_ME_strong_password_here
S3_ENDPOINT=http://minio:9000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=finlakehouse
AWS_SECRET_ACCESS_KEY=CHANGE_ME_strong_password_here

# --- Object store / storage (entity-scoped buckets) ---
OBJECT_STORE_PROVIDER=minio
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_EXTERNAL_ENDPOINT=http://localhost:9000
DATA_BUCKET=finlakehouse-data
BUCKET_NAME=finlakehouse-data
AUDIT_BUCKET=finlakehouse-audit
MLFLOW_ARTIFACT_BUCKET=finlakehouse-mlflow
MLFLOW_ARTIFACT_ROOT=s3://finlakehouse-mlflow/
WAREHOUSE_URI=s3a://finlakehouse-data/warehouse/

# --- Service endpoints ---
TRINO_URL=http://localhost:8080
OPENMETADATA_URL=http://localhost:8585
SUPERSET_URL=http://localhost:8088
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Superset (change secret key) ---
SUPERSET_SECRET_KEY=CHANGE_ME_finlakehouse_superset_secret
SUPERSET_DB_NAME=superset_metadata
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
SUPERSET_ADMIN_EMAIL=admin@finlakehouse.local
SUPERSET_TRINO_ICEBERG_DB_NAME=finlakehouse_trino_iceberg
SUPERSET_TRINO_ICEBERG_URI=
SUPERSET_TRINO_HIVE_DB_NAME=finlakehouse_trino_hive
SUPERSET_TRINO_HIVE_URI=
