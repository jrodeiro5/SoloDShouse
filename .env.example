HIVE_METASTORE_URI=thrift://localhost:9083

PRODUCT_ID=solodshouse
PRODUCT_DISPLAY_NAME=SoloDShouse
PRODUCT_DOMAIN=domain_agnostic
ENVIRONMENT=local
RUNTIME_VERSION=sds-v0.1.0
COMPOSE_PROJECT_NAME=solodshouse
TRINO_USER=solodshouse

# ── Object Store (SeaweedFS S3) ─────────────────────────────────────────────
OBJECT_STORE_ENDPOINT=http://localhost:8333
OBJECT_STORE_ACCESS_KEY=solodshouse
OBJECT_STORE_SECRET_KEY=solodshouse123
DATA_BUCKET=solodshouse-data
MLFLOW_ARTIFACT_BUCKET=solodshouse-mlflow
WAREHOUSE_URI=s3a://solodshouse-data/warehouse/

S3_ACCESS_KEY=solodshouse
S3_SECRET_KEY=solodshouse123
S3_ENDPOINT=http://seaweedfs:8333
AWS_ACCESS_KEY_ID=solodshouse
AWS_SECRET_ACCESS_KEY=solodshouse123

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
PG_PORT=5432

MLFLOW_S3_ENDPOINT_URL=http://seaweedfs:8333
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=s3://solodshouse-mlflow/

TRINO_URL=http://localhost:8080

# ── Connection Layer (SDS-044) ────────────────────────────────────────────────
SOLODSHOUSE_VAULT_KEY=
SOLODSHOUSE_JWT_SECRET=
SOLODSHOUSE_CONNECTIONS_PATH=config/connections.yaml

# ── Agent Layer ───────────────────────────────────────────────────────────────
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me
FASTAPI_PROXY_PORT=8000
OPEN_WEBUI_PORT=3001
OPEN_WEBUI_API_KEY=sk-dummy
WEBUI_SECRET_KEY=

# ── LLM Gateway (LiteLLM) ─────────────────────────────────────────────────────
LLM_API_BASE=http://localhost:8081/v1
LLM_API_KEY=not-needed
